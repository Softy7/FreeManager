{% extends 'base.html.twig' %}

{% block title %}Accueil - FreeManager{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="flex flex-col items-center gap-6 p-8">

    <div class="w-full max-w-md bg-white rounded-xl shadow-md border border-gray-100 p-6">
        <h3 class="text-sm font-bold text-gray-400 uppercase">Nombre de clients</h3>
        <p class="text-3xl font-black text-indigo-600 mt-2">{{ count_client }}</p>
    </div>

    <div class="w-full max-w-md bg-white rounded-xl shadow-md border border-gray-100 p-6">
        <h3 class="text-sm font-bold text-gray-400 uppercase">Devis en attente</h3>
        <p class="text-3xl font-black text-indigo-600 mt-2">{{ waiting_quote }}</p>
    </div>

    <div class="w-full max-w-md bg-white rounded-xl shadow-md border border-gray-100 p-6">
        <h3 class="text-sm font-bold text-gray-400 uppercase">Chiffre d'affaire</h3>
        <p class="text-3xl font-black text-indigo-600 mt-2">{{ ca_total }}</p>
    </div>

    <div class="w-full max-w-md bg-white rounded-xl shadow-md border border-gray-100 p-6">
        <h3 class="text-sm font-bold text-gray-400 uppercase">Devis validés</h3>
        <p class="text-3xl font-black text-indigo-600 mt-2">{{ accepted_quote }} %</p>
    </div>

</div>

{% endblock %}
