{# templates/ticket/new.html.twig #}

<div class="max-w-2xl mx-auto bg-white p-8 rounded-2xl shadow-sm border border-gray-100 mt-10">
    <h1 class="text-2xl font-bold text-gray-800 mb-6">Informations du ticket</h1>

    {% set labels = {
        'description': 'Description de la tâche',
        'quantity': 'Nombre de demi-journées estimées',
        'daily_rate': 'Taux journalier prévu',
        'priority': 'Indication de priorité sur le projet',
        'difficulty': 'Difficulté estimée',
        'quote': 'Devis'
    } %}

    {{ form_start(form) }}
    <div class="grid grid-cols-1 gap-5">
        {% for field in form %}
            {% if field.vars.name != '_token' %}
                <div class="flex flex-col">
                    <label class="block text-sm font-semibold text-gray-700 mb-1">
                        {{ labels[field.vars.name] ?? field.vars.name|capitalize }}
                    </label>

                    {# On définit les classes de base #}
                    {% set base_class = 'w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all outline-none bg-white' %}
                    
                    {# On ajoute dynamiquement une classe si c'est la description #}
                    {% if field.vars.name == 'description' %}
                        {% set field_class = base_class ~ ' min-h-[120px] resize-y' %}
                    {% else %}
                        {% set field_class = base_class %}
                    {% endif %}

                    {{ form_widget(field, {
                        'attr': {
                            'class': field_class,
                            'placeholder': labels[field.vars.name]
                        }
                    }) }}

                    <div class="text-red-500 text-xs mt-1">
                        {{ form_errors(field) }}
                    </div>
                </div>
            {% endif %}
        {% endfor %}

        <button class="mt-4 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-6 rounded-lg transition-colors shadow-md">
            {{ button_label|default('Enregistrer') }}
        </button>
    </div>
    {{ form_end(form) }}
</div>