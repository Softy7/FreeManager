<div class="flex justify-center items-center mt-6">
    <form method="post" action="{{ path('app_quote_delete', {'id': quote.id}) }}" 
          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce devis ? Cette action est irréversible.');">
        
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ quote.id) }}">
        
        <button class="inline-flex items-center px-6 py-2.5 bg-white text-red-600 font-semibold text-sm border-2 border-red-600 rounded-xl hover:bg-red-600 hover:text-white focus:ring-4 focus:ring-red-200 transition-all duration-200 group shadow-sm">
            <svg class="w-4 h-4 mr-2 text-red-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
            </svg>
            Supprimer le devis
        </button>
    </form>
</div>