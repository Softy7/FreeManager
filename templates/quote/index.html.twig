{% extends 'base.html.twig' %}

{% block title %}Quote index{% endblock %}

{% block body %}
    <div class="max-w-6xl mx-auto mt-10 px-4">
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Liste des devis</h1>
            <p class="text-sm text-gray-500 underline decoration-indigo-200">Suivi de votre facturation</p>
        </div>
        <a href="{{ path('app_quote_new') }}" class="inline-flex items-center px-5 py-2.5 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 transition-all shadow-md">
            <span class="mr-2">+</span> Nouveau devis
        </a>
    </div>

    <div class="shadow-xl rounded-2xl overflow-hidden border border-gray-100 bg-white">
        <table class="w-full text-left border-collapse">
            <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Id</th>
                    <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Réf</th>
                    <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Statut</th>
                    <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider text-right">Montant HT</th>
                    <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider text-center">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
            {% for quote in quotes %}
                <tr class="hover:bg-gray-50/50 transition-colors group">
                    <td class="px-6 py-4">
                        <span class="text-sm font-bold text-gray-900">
                            {{ quote.id }}
                        </span>
                    </td>
                    <td class="px-6 py-4">
                        <span class="text-sm font-mono font-bold text-indigo-600 bg-indigo-50 px-2 py-1 rounded">
                            {{ quote.reference }}
                        </span>
                    </td>
                    <td class="px-6 py-4">
                        {# Mapping des couleurs selon le status #}
                        {% set status_colors = {
                            0: 'bg-gray-100 text-gray-600',
                            1: 'bg-blue-100 text-blue-700',
                            2: 'bg-green-100 text-green-700',
                            3: 'bg-red-100 text-red-700',
                            4: 'bg-emerald-100 text-emerald-800 font-bold'
                        } %}
                        <span class="px-3 py-1 rounded-full text-xs font-medium {{ status_colors[quote.status] ?? 'bg-gray-100' }}">
                            {{ quote.statusLabel }}
                        </span>
                    </td>
                    <td class="px-6 py-4 text-right">
                        <span class="text-sm font-bold text-gray-900">
                            {{ quote.totalHt|number_format(2, ',', ' ') }} €
                        </span>
                    </td>
                    <td class="px-6 py-4 text-center">
                        <div class="flex justify-center gap-3">
                            <a href="{{ path('app_quote_edit', {'id': quote.id}) }}" class="text-gray-400 hover:text-amber-500 transition-colors" title="Éditer">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                            </a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="px-6 py-12 text-center text-gray-400 italic bg-gray-50/50">
                        Aucun devis enregistré pour le moment.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
